# GitHub Credentials
GITHUB_USERNAME=github_user
GITHUB_PAT=ghp_your_github_personal_access_token_here

# Quay.io Credentials
QUAY_USERNAME=quay_user
QUAY_PAT=your_quay_io_token_here

# Dashboard credentials for install.sh (all optional)
# Defaults: admin/admin logins; the Kargo token signing key is randomly
# generated on every install unless pinned here.
# Generate a bcrypt hash with: htpasswd -nbBC 10 "" 'yourpassword' | tr -d ':\n'
#ARGOCD_ADMIN_PASSWORD_HASH='$2a$10$...'
#KARGO_ADMIN_PASSWORD_HASH='$2a$10$...'
#KARGO_TOKEN_SIGNING_KEY=your_random_signing_key_here
